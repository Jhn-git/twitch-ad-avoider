[flake8]
max-line-length = 100
exclude =
    .git,
    .claude,
    __pycache__,
    build,
    dist,
    *.egg-info,
    venv,
    .venv,
    .eggs,
    .mypy_cache,
    .pytest_cache,
    build_cache
ignore =
    # Allow line breaks before binary operators (black-compatible)
    W503,
    # Ignore whitespace before ':' in slices (black-compatible)
    E203
